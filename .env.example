# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=jobseeker
DB_PASSWORD=jobseeker_secret
DB_NAME=jobseeker
DATABASE_URL=postgresql+asyncpg://jobseeker:jobseeker_secret@postgres:5432/jobseeker

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for platform credentials)
ENCRYPTION_KEY=your-fernet-key-generate-with-cryptography

# LLM Configuration (openai | anthropic | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OLLAMA_BASE_URL=http://localhost:11434

# Storage
STORAGE_PATH=./storage

# Proxy (optional, for scraping)
PROXY_URL=

# Application
APP_NAME=AI Job Seeker
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000
